cat << 'EOF' > .gitignore
############################################################
# R / RStudio
############################################################
.Rproj.user/
.Rhistory
.RData
.Ruserdata
*.Rproj

############################################################
# Large sequencing data (NEVER version control these)
############################################################
*.fastq
*.fastq.gz
*.fq
*.fq.gz
*.bam
*.sam
*.cram
*.bed
*.bedgraph
*.bw
*.bigWig

############################################################
# K-mer / count matrices / intermediate objects
############################################################
*.rds
*.RDS
*.rda
*.RData
*.qs
*.fst
*.h5
*.hdf5

############################################################
# DESeq2 / analysis outputs
############################################################
*.csv
*.tsv
*.xlsx
*.pdf
*.png
*.jpg
*.jpeg
*.svg
results/
output/
plots/
figures/

############################################################
# Alignment / mapping indexes
############################################################
*.bt2
*.bt2l
*.bwt
*.pac
*.ann
*.amb
*.sa
*.fai
*.mmi

############################################################
# Logs / temporary files
############################################################
*.log
*.out
*.err
nohup.out
*.tmp
*.swp
*~

############################################################
# Conda / environments
############################################################
env/
venv/
.conda/
*.yml

############################################################
# HPC scheduler files
############################################################
*.sbatch
*.slurm
slurm-*.out

############################################################
# OS junk
############################################################
.DS_Store
Thumbs.db

EOF